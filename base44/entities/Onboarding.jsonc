{
  "name": "Onboarding",
  "type": "object",
  "properties": {
    "client_id": {
      "type": "string"
    },
    "lead_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "Not Started",
        "In Progress",
        "Completed"
      ],
      "default": "Not Started"
    },
    "progress_percentage": {
      "type": "number",
      "default": 0
    },
    "next_action": {
      "type": "string"
    },
    "started_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "completed_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "description": {
      "type": "string",
      "maxLength": 1000,
      "description": "Optional description or notes (up to 1000 characters)"
    }
  },
  "required": [
    "client_id",
    "status"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": {
      "user_condition": {
        "role": "admin"
      }
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}