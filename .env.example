# Browser-safe values. VITE_ variables are embedded in the public bundle.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=replace_with_supabase_anon_key
VITE_VAPI_PUBLIC_KEY=replace_with_vapi_public_key
VITE_VAPI_ASSISTANT_ID=replace_with_vapi_assistant_id
VITE_ONESIGNAL_APP_ID=replace_with_onesignal_app_id
VITE_CRISP_WEBSITE_ID=replace_with_crisp_website_id
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Server-only values. Configure these in Vercel; never expose them in frontend code.
SITE_URL=https://www.assistantai.com.au
SUPABASE_SERVICE_ROLE_KEY=replace_in_vercel_only
SUPABASE_DB_URL=postgresql://postgres:YOUR_PASSWORD@db.your-project.supabase.co:5432/postgres

ADMIN_ACCESS_PASSWORD=replace_with_admin_password
ADMIN_SESSION_SECRET=replace_with_at_least_32_random_bytes
ANALYTICS_IP_HASH_SALT=replace_with_random_salt

STRIPE_MODE=test
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_TEST_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_STARTER_SETUP_PRICE_ID=price_replace_me
STRIPE_STARTER_PRICE_ID=price_replace_me
STRIPE_GROWTH_SETUP_PRICE_ID=price_replace_me
STRIPE_GROWTH_PRICE_ID=price_replace_me

VAPI_WEBHOOK_SECRET=replace_with_vapi_webhook_secret
VAPI_CALL_WEBHOOK_SECRET=replace_with_vapi_call_webhook_secret

GHL_API_KEY=replace_with_ghl_private_token
GHL_LOCATION_ID=replace_with_ghl_location_id
GHL_PIPELINE_ID=replace_with_ghl_pipeline_id
GHL_NEW_LEAD_STAGE_ID=replace_with_ghl_new_lead_stage_id

RESEND_API_KEY=replace_with_resend_api_key
RESEND_FROM_EMAIL=sales@assistantai.com.au
ADMIN_NOTIFICATION_EMAIL=sales@assistantai.com.au

TWILIO_ACCOUNT_SID=replace_with_twilio_account_sid
TWILIO_AUTH_TOKEN=replace_with_twilio_auth_token
TWILIO_FROM_NUMBER=+61XXXXXXXXX
ADMIN_NOTIFICATION_PHONE=+61XXXXXXXXX
